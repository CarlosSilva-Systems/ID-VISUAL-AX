# Configurações do Banco de Dados (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=odoo_backend

# Configurações de Cache (Redis)
REDIS_URL=redis://redis:6379/0

# Configurações do Backend (FastAPI)
# Gere uma SECRET_KEY segura usando: openssl rand -hex 32
SECRET_KEY=sua_chave_secreta_aqui
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Integração Odoo
ODOO_URL=https://axengenharia1.odoo.com
ODOO_DB=axengenharia1
ODOO_LOGIN=seu_email@exemplo.com
ODOO_PASSWORD=sua_senha_ou_apikey

# Inteligência Artificial
OPENROUTER_API_KEY=sua_chave_aqui

# Configurações do Frontend (Vite)
# Deixar vazio para usar URL relativa (/api/v1) via proxy do Vite — funciona em qualquer host.
# VITE_API_URL=http://localhost:8000/api/v1

# ─── OTA Management Configuration ──────────────────────────────────────────

# GitHub Integration (opcional - para downloads automáticos de firmware)
# Deixe em branco se não usar integração com GitHub
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
# Token necessário apenas para repositórios privados
GITHUB_TOKEN=

# Caminho de armazenamento de firmware OTA (ponto de montagem do volume Docker)
OTA_STORAGE_PATH=/app/storage/ota/firmware

# Host do backend para construção de URLs de firmware (usado pelos ESP32)
# Em produção: seu_dominio.com ou IP:porta
# Em desenvolvimento: localhost:8000
BACKEND_HOST=localhost:8000
