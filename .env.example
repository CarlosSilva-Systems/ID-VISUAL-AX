# Configurações do Banco de Dados (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=odoo_backend

# Configurações de Cache (Redis)
REDIS_URL=redis://redis:6379/0

# Configurações do Backend (FastAPI)
# Gere uma SECRET_KEY segura usando: openssl rand -hex 32
SECRET_KEY=sua_chave_secreta_aqui
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Integração Odoo
ODOO_URL=https://axengenharia1.odoo.com
ODOO_DB=axengenharia1
ODOO_LOGIN=seu_email@exemplo.com
ODOO_PASSWORD=sua_senha_ou_apikey

# Inteligência Artificial
OPENROUTER_API_KEY=sua_chave_aqui

# Configurações do Frontend (Vite)
VITE_API_URL=http://localhost:8000
