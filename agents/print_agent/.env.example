# URL base da API do app (sem barra final)
APP_URL=https://app.ax.com.br/api/v1

# ID da impressora cadastrada no sistema (tabela printer)
PRINTER_ID=1

# IP da impressora Zebra na rede local
PRINTER_IP=192.168.1.200

# Porta TCP da impressora (padrão Zebra: 9100)
PRINTER_PORT=9100

# Chave de autenticação do agente (deve bater com SystemSetting 'print_agent_key')
AGENT_KEY=chave-secreta-aqui

# Identificador único deste agente (aparece nos logs e no campo agent_id do job)
AGENT_ID=agente-bancada-1

# Intervalo de polling em segundos (quanto menor, mais rápido o job é processado)
POLL_INTERVAL_SECONDS=3

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
