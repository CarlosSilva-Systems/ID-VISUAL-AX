# Backend Environment Variables
PROJECT_NAME="Odoo Backend"
API_V1_STR="/api/v1"

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=odoo_backend
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/odoo_backend

# Security
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_SECRET_KEY_Generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Odoo Connection
ODOO_URL=https://axengenharia1.odoo.com
ODOO_DB=axengenharia1
ODOO_LOGIN=your_email@example.com
ODOO_PASSWORD=your_password_or_apikey
